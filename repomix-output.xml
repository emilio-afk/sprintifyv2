      /* ▼▼▼ REDISEÑO MODAL TAREA (Tipografias + Colores + Escala) ▼▼▼ */
      .modal-overlay {
        background: var(--modal-overlay);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
      }

      #modal-content {
        --modal-space-1: 8px;
        --modal-space-2: 12px;
        --modal-space-3: 16px;
        --modal-space-4: 24px;
        --modal-space-5: 32px;
        width: 100%;
        max-width: 1180px;
        background: #ffffff;
        border: 1px solid var(--modal-border);
        border-radius: 16px;
        box-shadow:
          0 24px 48px -18px rgba(15, 23, 42, 0.26),
          0 0 0 1px rgba(8, 145, 178, 0.06);
        padding: 0;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        font-family: var(--font-modal);
        color: var(--modal-text);
        max-height: min(94vh, 860px);
        animation: modal-pop 0.24s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      }
      #modal-content::after {
        content: none;
      }

      @keyframes modal-pop {
        0% {
          transform: scale(0.97) translateY(10px);
          opacity: 0;
        }
        100% {
          transform: scale(1) translateY(0);
          opacity: 1;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        #modal-content {
          animation: none;
        }
      }

      .modal-task-body-wrapper {
        display: grid;
        grid-template-columns: minmax(0, 1.65fr) minmax(340px, 1fr);
        gap: 0;
        flex: 1;
        min-height: 0;
      }

      @media (max-width: 768px) {
        .modal-task-body-wrapper {
          grid-template-columns: 1fr;
          display: flex;
          flex-direction: column;
        }
      }

      .modal-task-main-col {
        padding: var(--modal-space-4);
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: var(--modal-space-3);
        border-right: 1px solid var(--line-subtle);
        background: #ffffff;
      }

      .modal-task-side-col {
        padding: var(--modal-space-3);
        background: #f8fcff;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: var(--modal-space-2);
      }

      @media (max-width: 768px) {
        .modal-task-main-col {
          padding: var(--modal-space-3);
          border-right: none;
          border-bottom: 1px solid var(--line-subtle);
        }
        .modal-task-side-col {
          padding: var(--modal-space-3);
        }
      }

      .modal-top-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        min-height: 56px;
        padding: 14px 20px;
        border-bottom: 1px solid var(--line-subtle);
        background: color-mix(in srgb, var(--modal-surface-soft) 52%, #ffffff 48%);
        flex-shrink: 0;
      }

      .modal-top-bar-left {
        display: flex;
        align-items: center;
        gap: 12px;
      }
      .modal-top-bar-right {
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .modal-save-status {
        font-size: 0.72rem;
        font-weight: 600;
        color: var(--modal-text-muted);
        background: #ffffff;
        border: 1px solid var(--modal-border);
        border-radius: 999px;
        padding: 4px 10px;
        white-space: nowrap;
      }
      .modal-save-status.is-saving {
        color: var(--modal-primary-strong);
        border-color: color-mix(in srgb, var(--modal-primary) 38%, #d1e7ef 62%);
        background: #f0f9ff;
      }
      .modal-save-status.is-saved {
        color: #0f766e;
        border-color: #99f6e4;
        background: #ecfeff;
      }
      .modal-save-status.is-error {
        color: #b42318;
        border-color: #fecaca;
        background: #fff1f2;
      }

      .modal-sprint-badge {
        font-family: var(--font-modal);
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        color: var(--modal-primary-strong);
        background: var(--modal-surface-soft);
        padding: 5px 10px;
        border-radius: 999px;
        border: 1px solid var(--modal-border-strong);
      }

      .modal-close-icon {
        width: 34px;
        height: 34px;
        border-radius: 9px;
        color: var(--modal-text-muted);
        background: transparent;
        display: flex;
        align-items: center;
        justify-content: center;
        transition:
          background-color 0.18s ease,
