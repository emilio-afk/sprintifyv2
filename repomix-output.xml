        background: var(--modal-surface-muted);
        padding: 10px 12px;
        display: flex;
        flex-direction: column;
        gap: 4px;
      }

      .task-risk-indicator__tag {
        font-size: 0.73rem;
        font-weight: 800;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .task-risk-indicator__text {
        margin: 0;
        font-size: 0.8rem;
        line-height: 1.35;
      }

      .task-risk-indicator--neutral {
        border-color: var(--modal-border);
        background: var(--modal-surface-muted);
        color: var(--modal-text-muted);
      }

      .task-risk-indicator--low {
        border-color: #a7f3d0;
        background: #ecfdf5;
        color: #065f46;
      }

      .task-risk-indicator--medium {
        border-color: #fcd34d;
        background: #fffbeb;
        color: #92400e;
      }

      .task-risk-indicator--high {
        border-color: #fecaca;
        background: #fff1f2;
        color: #b42318;
      }

      .task-modal-error {
        margin: 0;
        border: 1px solid #fecaca;
        background: #fff1f2;
        color: #b42318;
        border-radius: 10px;
        padding: 8px 10px;
        font-size: 0.79rem;
        font-weight: 600;
      }

      .task-modal-feedback {
        margin: 0;
        border: 1px solid var(--modal-border);
        background: #f8fbff;
        color: var(--modal-text-muted);
        border-radius: 10px;
        padding: 8px 10px;
        font-size: 0.79rem;
        font-weight: 600;
      }

      .task-modal-feedback.is-loading {
        border-color: #99d4e5;
        background: #f0f9ff;
        color: #0e7490;
      }

      .task-modal-feedback.is-success {
        border-color: #86efac;
        background: #f0fdf4;
        color: #166534;
      }

      .task-modal-inline-actions {
        display: flex;
        justify-content: flex-end;
        gap: 8px;
      }

      .task-modal-btn {
        border-radius: 10px;
        font-size: 0.84rem;
        font-weight: 700;
        padding: 8px 14px;
        transition:
          border-color 0.18s ease,
          background-color 0.18s ease,
          color 0.18s ease,
          box-shadow 0.18s ease;
      }

      .task-modal-btn[disabled] {
        opacity: 0.6;
        cursor: not-allowed;
      }

      .task-modal-btn--ghost {
        border: 1px solid var(--modal-border-strong);
        background: #ffffff;
        color: var(--modal-primary-strong);
      }

      .task-modal-btn--ghost:hover {
        border-color: var(--modal-primary);
        background: var(--modal-surface-soft);
      }

      .task-modal-btn--solid {
        border: 1px solid transparent;
        background: var(--modal-cta);
        color: #ffffff;
        box-shadow: 0 4px 10px rgba(22, 163, 74, 0.2);
      }

      .task-modal-btn--solid:hover {
        background: var(--modal-cta-strong);
      }

      .task-points-modal-shell {
        gap: 10px;
      }

      .task-points-legend {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 6px;
      }

      .task-points-legend__item {
        border: 1px solid var(--modal-border);
        border-radius: 9px;
        background: var(--modal-surface-muted);
        padding: 6px 8px;
        font-size: 0.73rem;
        color: var(--modal-text-muted);
        text-align: center;
      }

      .task-factor-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
      }

      .task-factor-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
      }

      .task-factor-field label {
        font-size: 0.73rem;
        font-weight: 700;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        color: var(--modal-text-muted);
      }

      .task-factor-field--wide {
        grid-column: 1 / -1;
      }

      .task-points-summary-card {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
        border: 1px solid var(--modal-border);
        border-radius: 12px;
        background: var(--modal-surface-muted);
        padding: 10px 12px;
      }

      .task-points-summary-main {
        display: flex;
        flex-direction: column;
        gap: 3px;
      }

      .task-points-summary-main span {
        font-size: 0.72rem;
        font-weight: 700;
        color: var(--modal-text-muted);
        text-transform: uppercase;
        letter-spacing: 0.04em;
      }

      .task-points-summary-main strong {
        font-size: 1rem;
        line-height: 1.1;
        color: var(--modal-text);
      }

      #task-points-recommended-value.is-zero {
        color: #b42318;
      }

      .task-confidence-chip {
        align-self: center;
        justify-self: end;
        border-radius: 999px;
        border: 1px solid var(--modal-border);
        padding: 5px 10px;
        font-size: 0.73rem;
        font-weight: 800;
        letter-spacing: 0.03em;
        text-transform: uppercase;
      }

      .task-confidence-chip.is-high {
        border-color: #86efac;
        background: #f0fdf4;
        color: #166534;
      }

      .task-confidence-chip.is-medium {
        border-color: #fcd34d;
        background: #fffbeb;
        color: #92400e;
      }

      .task-confidence-chip.is-low {
        border-color: #fecaca;
        background: #fff1f2;
        color: #b42318;
      }

      .task-points-confidence-detail {
        margin: 0;
        font-size: 0.76rem;
        color: var(--modal-text-muted);
      }

      .task-modal-hint {
        margin: 0;
        font-size: 0.74rem;
        color: var(--modal-text-muted);
      }

      .task-modal-hint.is-required {
        color: #9f1239;
        font-weight: 700;
      }

      .task-quality-alert {
        border-radius: 10px;
        border: 1px solid #fcd34d;
        background: #fffbeb;
        color: #92400e;
        padding: 8px 10px;
        font-size: 0.78rem;
        font-weight: 600;
      }

      .task-quality-alert.is-warning {
        border-color: #fcd34d;
        background: #fffbeb;
        color: #92400e;
      }

      .task-quality-alert.is-danger {
        border-color: #fecaca;
        background: #fff1f2;
        color: #b42318;
      }

      @media (max-width: 760px) {
        .task-points-legend {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .task-factor-grid {
          grid-template-columns: 1fr;
        }

        .task-points-summary-card {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .task-confidence-chip {
          grid-column: 1 / -1;
          justify-self: start;
        }
      }

      .modal-feature-hidden {
        display: none !important;
      }
    </style>
  </head>
