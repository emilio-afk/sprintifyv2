  const sortedThemes = [...state.themes].sort(
    (a, b) => (a.createdAt?.seconds || 0) - (b.createdAt?.seconds || 0)
  );

  sortedThemes.forEach((theme) => {
    const themeEpics = state.epics.filter((e) => e.themeId === theme.id);
