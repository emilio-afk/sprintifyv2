<script>
  (() => {
    // fas -> fa-solid
    document.querySelectorAll("i.fas").forEach((i) => i.classList.replace("fas", "fa-solid"));
    // fa-trash-alt -> fa-trash-can (renombre en v6)
    document.querySelectorAll("i.fa-trash-alt").forEach((i) => {
      i.classList.remove("fa-trash-alt");
      i.classList.add("fa-trash-can");
    });
    // Asegurar medida/visibilidad
    document.querySelectorAll("i.fa-solid").forEach((i) => {
      i.classList.add("fa-fw", "inline-block");
      if (![...i.classList].some((c) => /^w-/.test(c))) i.classList.add("w-5", "h-5");
      if (![...i.classList].some((c) => /^text-/.test(c))) i.classList.add("text-current");
    });
  })();
</script>
