  updateSprintCapacity(sprintId, newCapacity) {
    const cap = Number(newCapacity);
    if (!sprintId || Number.isNaN(cap)) return;
    updateDoc(doc(listsCollection, sprintId), { capacity: cap }).catch(console.error);
